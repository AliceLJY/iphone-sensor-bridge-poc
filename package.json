{
  "name": "iphone-sensor-bridge-poc",
  "version": "0.1.0",
  "private": true,
  "description": "Local phone-to-Mac file drop prototype over a browser-accessible HTTP bridge.",
  "main": "server.js",
  "scripts": {
    "start": "HOSTS=127.0.0.1,0.0.0.0 PORT=8765 INBOX=$HOME/Desktop/iphone-sensor-inbox-v2 node server.js",
    "check": "node --check server.js",
    "launchd:install": "bash scripts/install-launchd.sh"
  },
  "engines": {
    "node": ">=18"
  }
}
